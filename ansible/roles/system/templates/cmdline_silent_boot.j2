{#-
  Token-level rewrite of cmdline.txt for silent boot.

  - Move the kernel console off the visible tty (tty1 -> tty3). Anything not
    silenced by `quiet` ends up on tty3, which nothing else paints.
  - Append loglevel=0 and logo.nologo if missing, idempotently.

  Pure string ops — no regex.
-#}
{%- set tokens = (system_cmdline_current.content | b64decode | trim).split() -%}
{%- set rewritten = [] -%}
{%- for tok in tokens -%}
{%-   if tok == 'console=tty1' -%}
{%-     set _ = rewritten.append('console=tty3') -%}
{%-   else -%}
{%-     set _ = rewritten.append(tok) -%}
{%-   endif -%}
{%- endfor -%}
{%- for required in ['loglevel=0', 'logo.nologo'] -%}
{%-   if required not in rewritten -%}
{%-     set _ = rewritten.append(required) -%}
{%-   endif -%}
{%- endfor -%}
{{ rewritten | join(' ') }}
