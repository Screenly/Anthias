{#-
  Anthias-managed cmdline.txt. Renders from cmdline.txt.orig (the factory
  cmdline captured on first install) and reapplies every Anthias-managed
  parameter deterministically — pure string ops, no regex.

  Behaviour:
    - console=tty1 -> console=tty3 (silent boot: kernel console off the
      visible tty)
    - any token already in `anthias_managed` is stripped from the orig
      tokens before being re-appended in canonical order — guarantees
      idempotency and a stable output even if the orig has stale values
      from a previous install.
-#}
{%- set anthias_managed = [
      'splash',
      'vt.global_cursor_default=0',
      'plymouth.ignore-serial-consoles',
      'quiet',
      'init=/lib/systemd/systemd',
      'net.ifnames=0',
      'cgroup_enable=memory',
      'cgroup_memory=1',
      'loglevel=0',
      'logo.nologo',
    ] -%}
{%- set orig_tokens = (system_cmdline_orig.content | b64decode | trim).split() -%}
{%- set carried = [] -%}
{%- for tok in orig_tokens -%}
{%-   if tok == 'console=tty1' -%}
{%-     set _ = carried.append('console=tty3') -%}
{%-   elif tok in anthias_managed -%}
{#- drop; will be reappended in canonical order -#}
{%-   else -%}
{%-     set _ = carried.append(tok) -%}
{%-   endif -%}
{%- endfor -%}
{%- for p in anthias_managed -%}
{%-   set _ = carried.append(p) -%}
{%- endfor -%}
{{ carried | join(' ') }}
