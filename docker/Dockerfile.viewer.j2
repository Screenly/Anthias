# syntax=docker/dockerfile:1.4
# vim: ft=dockerfile
{% include 'uv-builder.j2' %}

{% if is_qt6 %}
{# Qt 6 boards (pi4-64, pi5, x86): Debian apt provides qt6-base-dev
   and qt6-webengine-dev directly, so the builder stage runs at the
   target platform (under QEMU on x86 build hosts) and just qmake's
   the in-tree webview/ source. #}
FROM {{ base_image }}:{{ base_image_tag }} AS webview-builder
USER root
{% if disable_cache_mounts %}
RUN \
{% else %}
RUN --mount=type=cache,target=/var/cache/apt,id=qt6-builder-apt-{{ artifact_board }},sharing=locked \
{% endif %}
    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        qt6-base-dev \
        qt6-webengine-dev
COPY webview/AnthiasWebview.pro /src/webview/AnthiasWebview.pro
COPY webview/src /src/webview/src
COPY webview/res /src/webview/res
WORKDIR /src/webview
# webview is 3 .cpp files (~6s on x86 native, ~30s under arm64 QEMU);
# adding ccache would only save a couple of seconds on incremental
# rebuilds and the cache mount + apt install + PATH wiring would
# outweigh the saving.
RUN qmake6 && \
    make -j"$(nproc)" && \
    make install
RUN mkdir -p /out/bin /out/share/AnthiasWebview && \
    mv AnthiasWebview /out/bin/ && \
    cp -r /src/webview/res /out/share/AnthiasWebview/
{% else %}
{% include 'Dockerfile.qt5-webview-builder.j2' %}
{% endif %}

{% include 'Dockerfile.base.j2' %}

{% if disable_cache_mounts %}
RUN \
{% else %}
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
{% endif %}
    apt-get update && \
    apt-get -y install --no-install-recommends \
    {% for dependency in viewer_extra_apt_dependencies -%}
        {% if not loop.last %}
        {{ dependency }} \
        {% else %}
        {{ dependency }}
        {% endif %}
    {% endfor %}

COPY --from=uv-builder /venv /venv
ENV PATH="/venv/bin:$PATH"
ENV VIRTUAL_ENV="/venv"

{% if not is_qt6 %}
# Qt 5 boards: copy the whole qt5pi tree to its configured runtime
# prefix (-prefix /usr/local/qt5pi at toolchain build time). Qt 6
# boards get their runtime libs from qt6-*-dev installed above.
COPY --from=webview-builder /out/qt5pi /usr/local/qt5pi
{% endif %}
COPY --from=webview-builder /out/bin/AnthiasWebview /usr/local/bin/AnthiasWebview
COPY --from=webview-builder /out/share/AnthiasWebview /usr/local/share/AnthiasWebview

ENV QT_QPA_EGLFS_FORCE888=1
{% if is_qt6 %}
# All Qt6 boards run the viewer under `cage`, a kiosk Wayland
# compositor that talks to KMS via wlroots. bin/start_viewer.sh wraps
# the viewer process in cage; this env var tells Qt to load the
# qt6-wayland platform plugin so it renders into cage's surface.
# Covers x86 (balenaOS doesn't expose /dev/fb0), arm64 Armbian
# boards (Rock Pi / Orange Pi / Banana Pi, …), and the Pi4-64 / Pi5
# (consolidated onto Wayland so all Qt6 boards share one display
# stack — see #TBD).
ENV QT_QPA_PLATFORM=wayland
{% else %}
ENV QT_QPA_PLATFORM=linuxfb
{% endif %}

# Turn on debug logging for now
#ENV QT_LOGGING_RULES=qt.qpa.*=true
ENV QT_LOGGING_RULES=*.debug=true
ENV QT_QPA_DEBUG=1

ENV GIT_HASH={{ git_hash }}
ENV GIT_SHORT_HASH={{ git_short_hash }}
ENV GIT_BRANCH={{ git_branch }}
ENV DEVICE_TYPE={{ device_type }}
ENV DJANGO_SETTINGS_MODULE="anthias_server.django_project.settings"
ENV PYTHONPATH="/usr/src/app/src"
ENV ANTHIAS_SERVICE="viewer"

RUN useradd -g video viewer

RUN rm -f /etc/localtime

WORKDIR /usr/src/app
RUN mkdir -p /usr/src/app
COPY . /usr/src/app/

CMD ["bash", "./bin/start_viewer.sh"]
