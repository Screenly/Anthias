# syntax=docker/dockerfile:1.4
# vim: ft=dockerfile
{% include 'uv-builder.j2' %}

{% if is_qt6 %}
{# Qt 6 boards (pi4-64, pi5, x86): Debian apt provides qt6-base-dev
   and qt6-webengine-dev directly, so the builder stage runs at the
   target platform (under QEMU on x86 build hosts) and just qmake's
   the in-tree webview/ source. #}
FROM {{ base_image }}:{{ base_image_tag }} AS webview-builder
USER root
{% if disable_cache_mounts %}
RUN \
{% else %}
RUN --mount=type=cache,target=/var/cache/apt,id=qt6-builder-apt-{{ artifact_board }},sharing=locked \
{% endif %}
    apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        qt6-base-dev \
        qt6-webengine-dev
COPY webview/AnthiasWebview.pro /src/webview/AnthiasWebview.pro
COPY webview/src /src/webview/src
COPY webview/res /src/webview/res
WORKDIR /src/webview
# webview is 3 .cpp files (~6s on x86 native, ~30s under arm64 QEMU);
# adding ccache would only save a couple of seconds on incremental
# rebuilds and the cache mount + apt install + PATH wiring would
# outweigh the saving.
RUN qmake6 && \
    make -j"$(nproc)" && \
    make install
RUN mkdir -p /out/bin /out/share/AnthiasWebview && \
    mv AnthiasWebview /out/bin/ && \
    cp -r /src/webview/res /out/share/AnthiasWebview/
{% else %}
{% include 'Dockerfile.qt5-webview-builder.j2' %}
{% endif %}

{% include 'Dockerfile.base.j2' %}

{% if board in ('pi4-64', 'pi5') %}
# archive.raspberrypi.com ships mpv + the FFmpeg stack patched with
# Pi-specific v4l2request hwdec — stock Debian Trixie's mpv 0.40
# doesn't include the v4l2request hwdec the Hantro stateless
# decoder on Pi 5 needs (Pi 4's V3D V4L2 M2M decoder works via
# stock mpv's v4l2m2m-copy too, but using the Pi-patched mpv on
# both boards keeps Pi userspace on a single upstream). x86 and
# arm64 stay on stock Debian — VAAPI on x86 already works, and
# Pi's repo isn't tuned for Rockchip / generic ARM hardware.
#
# Apt pinning restricts the Pi repo to the mpv + FFmpeg library
# family only. Without this, Pi's curl, ca-certificates, etc.
# would silently shadow Debian's versions and we'd drift away
# from the rest of the image's apt baseline.
{% if disable_cache_mounts %}
RUN \
{% else %}
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
{% endif %}
    set -o pipefail; \
    apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    install -d -m 0755 /etc/apt/keyrings && \
    curl -fsSL --retry 3 \
        https://archive.raspberrypi.com/debian/pool/main/r/raspberrypi-archive-keyring/raspberrypi-archive-keyring_2025.1+rpt1_all.deb \
        -o /tmp/raspberrypi-archive-keyring.deb && \
    dpkg-deb -x /tmp/raspberrypi-archive-keyring.deb /tmp/raspberrypi-keyring && \
    install -m 0644 \
        /tmp/raspberrypi-keyring/usr/share/keyrings/raspberrypi-archive-keyring.pgp \
        /etc/apt/keyrings/raspberrypi-archive.pgp && \
    rm -rf /tmp/raspberrypi-archive-keyring.deb /tmp/raspberrypi-keyring && \
    echo "deb [signed-by=/etc/apt/keyrings/raspberrypi-archive.pgp] https://archive.raspberrypi.com/debian/ trixie main" \
        > /etc/apt/sources.list.d/raspberrypi.list && \
    printf '%s\n' \
        'Package: mpv libavcodec* libavdevice* libavfilter* libavformat* libavutil* libpostproc* libswresample* libswscale* ffmpeg' \
        'Pin: origin archive.raspberrypi.com' \
        'Pin-Priority: 1001' \
        '' \
        'Package: *' \
        'Pin: origin archive.raspberrypi.com' \
        'Pin-Priority: 100' \
        > /etc/apt/preferences.d/raspberrypi
# The bare `raspberrypi.gpg.key` ASCII key on the Pi website still
# carries SHA1 binding signatures (RSA 2048, generated 2012-06-17)
# that Trixie's sqv refuses to certify under its post-2026-02-01
# crypto policy ("Signing key … is not bound: No binding signature
# at time …, SHA1 is not considered secure since 2026-02-01"). The
# *deb-packaged* keyring `raspberrypi-archive-keyring_*.pgp` ships
# the same key fingerprint but with rebuilt binding signatures that
# sqv accepts — that's the keyring Pi OS Trixie itself installs and
# the reason `apt update` works on a real Pi 5 today. Fetching it
# directly here gives us the same verified path without depending
# on Pi's apt repo being reachable for an apt install (chicken-and-
# egg). Pin to a known-good version so a regenerated keyring deb
# can't silently change what we trust.
{% endif %}

{% if disable_cache_mounts %}
RUN \
{% else %}
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
{% endif %}
    apt-get update && \
    apt-get -y install --no-install-recommends \
    {% for dependency in viewer_extra_apt_dependencies -%}
        {% if not loop.last %}
        {{ dependency }} \
        {% else %}
        {{ dependency }}
        {% endif %}
    {% endfor %}

COPY --from=uv-builder /venv /venv
ENV PATH="/venv/bin:$PATH"
ENV VIRTUAL_ENV="/venv"

{% if not is_qt6 %}
# Qt 5 boards: copy the whole qt5pi tree to its configured runtime
# prefix (-prefix /usr/local/qt5pi at toolchain build time). Qt 6
# boards get their runtime libs from qt6-*-dev installed above.
COPY --from=webview-builder /out/qt5pi /usr/local/qt5pi
{% endif %}
COPY --from=webview-builder /out/bin/AnthiasWebview /usr/local/bin/AnthiasWebview
COPY --from=webview-builder /out/share/AnthiasWebview /usr/local/share/AnthiasWebview

ENV QT_QPA_EGLFS_FORCE888=1
{% if board in ('x86', 'arm64', 'pi5') %}
# x86 / arm64 / pi5 run the viewer under `cage`, a kiosk wlroots
# compositor that talks straight to KMS. bin/start_viewer.sh wraps
# the viewer in cage; this env var tells Qt to load the qt6-wayland
# platform plugin so it renders into cage's surface.
ENV QT_QPA_PLATFORM=wayland
{% else %}
# Pi 4 (Qt6) and Pi 2 / Pi 3 (Qt5) keep the classic linuxfb path —
# the Pi 4 V3D 6.0 can't keep up with cage's composite pass on top
# of video, so the viewer renders directly to the framebuffer.
ENV QT_QPA_PLATFORM=linuxfb
{% endif %}

# Turn on debug logging for now
#ENV QT_LOGGING_RULES=qt.qpa.*=true
ENV QT_LOGGING_RULES=*.debug=true
ENV QT_QPA_DEBUG=1

ENV GIT_HASH={{ git_hash }}
ENV GIT_SHORT_HASH={{ git_short_hash }}
ENV GIT_BRANCH={{ git_branch }}
ENV DEVICE_TYPE={{ device_type }}
ENV DJANGO_SETTINGS_MODULE="anthias_server.django_project.settings"
ENV PYTHONPATH="/usr/src/app/src"
ENV ANTHIAS_SERVICE="viewer"

RUN useradd -g video viewer

RUN rm -f /etc/localtime

WORKDIR /usr/src/app
RUN mkdir -p /usr/src/app
COPY . /usr/src/app/

CMD ["bash", "./bin/start_viewer.sh"]
